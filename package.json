{
  "name": "github-stats-enhanced",
  "version": "0.1.1",
  "description": "Generate GitHub stats SVG cards via GitHub Actions",
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target node",
    "start": "bun src/index.ts",
    "type-check": "tsc --noEmit",
    "test:local": "bun scripts/test-local.ts",
    "test:fetch": "bun scripts/test-local.ts --fetch-only",
    "test:generate": "bun scripts/test-local.ts --from-cache"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@primer/octicons": "^19.25.0",
    "js-yaml": "^4.1.1"
  }
}
